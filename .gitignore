*.jpeg
*.png
*.jpg

# Keep images in the zayn/ folder
!zayn/*.jpeg
!zayn/*.png
!zayn/*.jpg

# Keep hero section images in root if needed
!hero section 1.PNG
!hero section 2.jpeg

# Exclude VS Code settings
.vscode/

